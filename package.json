{
  "name": "arco",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev": "turbo dev",
    "video:preview": "pnpm --filter @arco/video preview:sample",
    "video:render": "pnpm --filter @arco/video render:sample",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  }
}
