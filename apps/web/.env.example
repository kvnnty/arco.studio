# Must match apps/api JWT_SECRET exactly (used to verify access tokens in middleware)
JWT_SECRET=change-me-in-production

# Server-side API calls (Next.js server components, actions, route handlers)
API_URL=http://localhost:8000/api

# Public API URL — used by the browser and server; set to your deployed API in production
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Public web app URL (referral links, OAuth redirects via API WEB_APP_URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — error monitoring (requires user consent via cookie banner)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# Optional — analytics (requires user consent via cookie banner)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional — Sentry upload during next build
# SENTRY_ORG=
# SENTRY_PROJECT=
