# Server
PORT=8000

# ── Local development ──────────────────────────────────────────────────────────
# CORS_ORIGIN=http://localhost:3000
# API_PUBLIC_URL=http://localhost:8000
# WEB_APP_URL=http://localhost:3000

# ── Production (uncomment and replace) ───────────────────────────────────────
# CORS_ORIGIN=https://arco.app
# API_PUBLIC_URL=https://api.arco.app
# WEB_APP_URL=https://arco.app

# Comma-separated origins allowed to call the API (must include your web app URL)
CORS_ORIGIN=http://localhost:3000

# Public URL of this API — used for OAuth callbacks and headless render asset URLs
API_PUBLIC_URL=http://localhost:8000

# Optional — enables LLM draft generation (falls back to heuristic without it)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Clerk managed authentication.
CLERK_SECRET_KEY=
# PEM public key from Clerk Dashboard -> API keys -> JWT public key.
# Single line with \n between PEM rows (multi-line .env only reads the first line).
CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# Comma-separated web origins accepted in the token azp claim.
CLERK_AUTHORIZED_PARTIES=http://localhost:3000

WEB_APP_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/arco?schema=public"

# S3 / MinIO (local dev via docker compose)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=arco-uploads
S3_PUBLIC_URL=http://localhost:9000/arco-uploads
S3_FORCE_PATH_STYLE=true

# Production AWS example:
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=arco-uploads-prod
# S3_FORCE_PATH_STYLE=false
# (omit S3_ENDPOINT and S3_PUBLIC_URL — uses AWS defaults + presigned/proxy URLs)

# Polar billing — Merchant of Record (https://polar.sh/docs)
# Organization access token scopes: checkouts:write, customer_sessions:write, customers:read
POLAR_ACCESS_TOKEN=
# Webhook signing secret from Polar Dashboard → Webhooks
POLAR_WEBHOOK_SECRET=
# production | sandbox
POLAR_SERVER=production

# Product IDs from Polar Dashboard → Products
# Intro $9/mo, Pro $29/mo or $288/yr, Studio $59/mo or $588/yr
POLAR_PRODUCT_TRIAL_MONTHLY=
POLAR_PRODUCT_PRO_MONTHLY=
POLAR_PRODUCT_PRO_ANNUAL=
POLAR_PRODUCT_STUDIO_MONTHLY=
POLAR_PRODUCT_STUDIO_ANNUAL=

# Local:
POLAR_SUCCESS_URL=http://localhost:3000/dashboard/billing?checkout=success
POLAR_RETURN_URL=http://localhost:3000/dashboard/billing?checkout=canceled
POLAR_PORTAL_RETURN_URL=http://localhost:3000/dashboard/billing
# Production:
# POLAR_SUCCESS_URL=https://arco.app/dashboard/billing?checkout=success
# POLAR_RETURN_URL=https://arco.app/dashboard/billing?checkout=canceled
# POLAR_PORTAL_RETURN_URL=https://arco.app/dashboard/billing

# Credit billing (metered usage)
MONTHLY_CREDITS_TRIAL=200
MONTHLY_CREDITS_PRO=1250
MONTHLY_CREDITS_STUDIO=3000
TOPUP_CREDITS_AMOUNT=200
POLAR_PRODUCT_TOPUP=
REFERRAL_CREDITS_PER_SIGNUP=200

# Credit costs per action
CREDIT_COST_AI_DRAFT=25
CREDIT_COST_AI_STORYBOARD=30
CREDIT_COST_AI_CHAT=5
CREDIT_COST_AI_REFINE=10
CREDIT_COST_AI_REGENERATE=8
CREDIT_COST_VOICE_GENERATE=40
CREDIT_COST_VOICE_PREVIEW=5
# Exports are included with the plan (0 credits). Quality still gated by plan.
CREDIT_COST_EXPORT_720P=0
CREDIT_COST_EXPORT_1080P=0
CREDIT_COST_EXPORT_4K=0

# Legacy project slot env vars (deprecated — no longer enforced)
ACTIVE_PROJECT_LIMIT_TRIAL=5
ACTIVE_PROJECT_LIMIT_PRO=15
ACTIVE_PROJECT_LIMIT_STUDIO=9999

# ElevenLabs voiceover (Phase 3 — screenshot mode)
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
