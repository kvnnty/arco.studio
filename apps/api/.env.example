# Server
PORT=8000

# Comma-separated origins allowed to call the API (Next.js dev server)
CORS_ORIGIN=http://localhost:3000

# Public URL for resolving relative recording paths during headless render
API_PUBLIC_URL=http://localhost:8000

# Optional — enables LLM draft generation (falls back to heuristic without it)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Auth — change in production (shared between API and web middleware)
JWT_SECRET=change-me-in-production

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM="Arco <hello@arco.app>"
WEB_APP_URL=http://localhost:3000

# OAuth — register callback URLs with each provider:
# Google:  {API_PUBLIC_URL}/api/auth/oauth/google/callback
# GitHub:  {API_PUBLIC_URL}/api/auth/oauth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/arco?schema=public"

# S3 / MinIO (local dev via docker compose)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=arco-uploads
S3_PUBLIC_URL=http://localhost:9000/arco-uploads
S3_FORCE_PATH_STYLE=true

# Production AWS example:
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=arco-uploads-prod
# S3_FORCE_PATH_STYLE=false
# (omit S3_ENDPOINT and S3_PUBLIC_URL — uses AWS defaults + presigned/proxy URLs)

# Polar billing — Merchant of Record (https://polar.sh/docs)
# Organization access token scopes: checkouts:write, customer_sessions:write, customers:read
POLAR_ACCESS_TOKEN=
# Webhook signing secret from Polar Dashboard → Webhooks
POLAR_WEBHOOK_SECRET=
# production | sandbox
POLAR_SERVER=production

# Product IDs from Polar Dashboard → Products
# Intro $9/mo, Pro $29/mo or $288/yr, Studio $59/mo or $588/yr
POLAR_PRODUCT_TRIAL_MONTHLY=
POLAR_PRODUCT_PRO_MONTHLY=
POLAR_PRODUCT_PRO_ANNUAL=
POLAR_PRODUCT_STUDIO_MONTHLY=
POLAR_PRODUCT_STUDIO_ANNUAL=

POLAR_SUCCESS_URL=http://localhost:3000/dashboard/billing?checkout=success
POLAR_RETURN_URL=http://localhost:3000/dashboard/billing?checkout=canceled
POLAR_PORTAL_RETURN_URL=http://localhost:3000/dashboard/billing

# Active project slots (delete to free a slot; re-exports are unlimited)
ACTIVE_PROJECT_LIMIT_TRIAL=5
ACTIVE_PROJECT_LIMIT_PRO=15
ACTIVE_PROJECT_LIMIT_STUDIO=9999

# ElevenLabs voiceover (Phase 3 — screenshot mode)
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

