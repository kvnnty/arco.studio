model AuthSession {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String    @unique
  familyId         String
  expiresAt        DateTime
  revokedAt        DateTime?
  ipAddress        String?
  userAgent        String?
  deviceLabel      String?
  lastUsedAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}
