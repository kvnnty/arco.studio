model User {
  id                    String       @id @default(cuid())
  email                 String       @unique
  name                  String?
  passwordHash          String
  createdAt             DateTime     @default(now())
  stripeCustomerId      String?      @unique
  stripeSubscriptionId  String?      @unique
  planStatus            String       @default("inactive")
  plan                  String?
  exportAllowance       Int          @default(15)
  exportsUsedThisPeriod Int          @default(0)
  periodEnd             DateTime?
  hadLaunchOffer        Boolean      @default(false)
  projects              Project[]
  usageEvents           UsageEvent[]
}
