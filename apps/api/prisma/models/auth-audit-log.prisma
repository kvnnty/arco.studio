model AuthAuditLog {
  id        String   @id @default(cuid())
  userId    String?
  event     String
  ipAddress String?
  userAgent String?
  metadata  String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([event])
  @@index([createdAt])
}
