{
  "name": "@arco/project-schema",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./style-presets": {
      "types": "./dist/style-presets.d.ts",
      "default": "./dist/style-presets.js"
    },
    "./music": {
      "types": "./dist/music.d.ts",
      "default": "./dist/music.js"
    },
    "./sound-design": {
      "types": "./dist/sound-design.d.ts",
      "default": "./dist/sound-design.js"
    },
    "./templates": {
      "types": "./dist/templates.d.ts",
      "default": "./dist/templates.js"
    },
    "./voices": {
      "types": "./dist/voices.d.ts",
      "default": "./dist/voices.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@arco/typescript-config": "workspace:*",
    "typescript": "^5.8.2"
  }
}
